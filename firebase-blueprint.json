{
  "entities": {
    "Author": {
      "title": "Author",
      "description": "An author's public profile data linked by uid",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "shortId": { "type": "number" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "shortId", "displayName"]
    },
    "User": {
      "title": "User",
      "description": "A registered author for the Tadabbur blog.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "timestamp" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["email", "name", "createdAt", "updatedAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A Tadabbur article written by an author.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "verse": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "timestamp" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["authorId", "authorName", "verse", "content", "category", "tags", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/authors/{authorId}": {
      "schema": { "$ref": "#/entities/Author" },
      "description": "Public author profiles including a short ID for cleaner URLs."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles. Only allowed authors can create their profile."
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Tadabbur posts."
    }
  }
}
